# -----------------------------------------------------------------------------
# Appointment Scheduling Agent — example environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# -----------------------------------------------------------------------------

# --- Core ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# When true, MCP calendar/email tools use in-memory FAKE providers (no Google
# calls) and the agent uses a local model adapter. Ideal for tests & demos.
FAKE_PROVIDERS=true

# --- Database (Postgres = system of record) ---
DATABASE_URL=postgresql+psycopg://appt:appt@localhost:5432/appointments

# --- Scheduling defaults ---
DEFAULT_OPENING_START=09:00
DEFAULT_OPENING_END=17:00
SLOT_MINUTES=30
DEFAULT_TIMEZONE=UTC

# --- Message queue (Azure Service Bus). For local dev a stub queue is used
#     automatically when FAKE_PROVIDERS=true. ---
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_QUEUE_NAME=appointment-requests

# --- Remote MCP server URLs (Streamable HTTP) ---
MCP_RESOURCE_DETAILS_URL=http://localhost:8081/mcp
MCP_CALENDAR_URL=http://localhost:8082/mcp
MCP_EMAIL_URL=http://localhost:8083/mcp
# Shared API key the agent presents to the remote MCP servers.
MCP_API_KEY=local-dev-key

# --- Magic-link auth ---
MAGIC_LINK_SECRET=change-me-in-prod
MAGIC_LINK_TTL_MINUTES=15
PUBLIC_BASE_URL=http://localhost:8080

# --- Google (only used when FAKE_PROVIDERS=false) ---
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GMAIL_SENDER=appointments@example.com

# --- Azure AI Foundry (only used when FAKE_PROVIDERS=false) ---
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_AGENT_MODEL=gpt-4o-mini